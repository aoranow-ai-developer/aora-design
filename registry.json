{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "aoranow",
  "homepage": "https://github.com/aoranow-ai-developer/aora-design",
  "items": [
    {
      "name": "theme",
      "type": "registry:file",
      "title": "AoraNow theme",
      "description": "AoraNow tokens (colors/radius/fonts, light + .dark) — Tailwind v4. Consume with @import \"./aora-theme.css\".",
      "files": [
        { "path": "src/aora-theme.css", "type": "registry:file", "target": "src/aora-theme.css" }
      ]
    },
    {
      "name": "status-badge",
      "type": "registry:component",
      "title": "StatusBadge",
      "description": "Status badge (color + icon + label; never color-only). Vocabulary aprovado/revisao/descartado/stale.",
      "dependencies": ["lucide-react"],
      "files": [
        { "path": "src/components/aora/status-badge.tsx", "type": "registry:component", "target": "components/aora/status-badge.tsx" }
      ]
    },
    {
      "name": "empty-state",
      "type": "registry:component",
      "title": "EmptyState",
      "description": "Empty state (icon + title + description + CTA).",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["button"],
      "files": [
        { "path": "src/components/aora/empty-state.tsx", "type": "registry:component", "target": "components/aora/empty-state.tsx" }
      ]
    },
    {
      "name": "error-state",
      "type": "registry:component",
      "title": "ErrorState",
      "description": "Error state (icon + message + retry; role=alert).",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["button"],
      "files": [
        { "path": "src/components/aora/error-state.tsx", "type": "registry:component", "target": "components/aora/error-state.tsx" }
      ]
    },
    {
      "name": "kpi-card",
      "type": "registry:component",
      "title": "KpiCard",
      "description": "KPI tile (value + delta + hint).",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["card"],
      "files": [
        { "path": "src/components/aora/kpi-card.tsx", "type": "registry:component", "target": "components/aora/kpi-card.tsx" }
      ]
    },
    {
      "name": "data-table",
      "type": "registry:component",
      "title": "DataTable",
      "description": "Generic dense table DataTable<T> (TanStack): sort, filter, selection, pagination, sticky header.",
      "dependencies": ["@tanstack/react-table", "lucide-react"],
      "registryDependencies": ["button", "input", "table"],
      "files": [
        { "path": "src/components/aora/data-table.tsx", "type": "registry:component", "target": "components/aora/data-table.tsx" }
      ]
    },
    {
      "name": "app-shell",
      "type": "registry:component",
      "title": "AppShell",
      "description": "Dashboard shell (sidebar + topbar), nav via props.",
      "dependencies": ["lucide-react"],
      "registryDependencies": ["button", "avatar"],
      "files": [
        { "path": "src/components/aora/app-shell.tsx", "type": "registry:component", "target": "components/aora/app-shell.tsx" }
      ]
    },
    {
      "name": "base",
      "type": "registry:block",
      "title": "AoraNow base kit",
      "description": "Bundle: theme + all components of the AoraNow design system.",
      "registryDependencies": [
        "@aoranow/theme",
        "@aoranow/status-badge",
        "@aoranow/empty-state",
        "@aoranow/error-state",
        "@aoranow/kpi-card",
        "@aoranow/data-table",
        "@aoranow/app-shell"
      ],
      "files": []
    },
    {
      "name": "design",
      "type": "registry:file",
      "title": "DESIGN.md",
      "description": "Design guide (design-system-as-text) read by the agent before building UI.",
      "files": [
        { "path": "DESIGN.md", "type": "registry:file", "target": "DESIGN.md" }
      ]
    }
  ]
}
